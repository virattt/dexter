# LLM API Keys
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
XAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-api-key
MOONSHOT_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# =============================================
# Financial Data Providers
# =============================================

# Financial Datasets API (US fundamentals)
FINANCIAL_DATASETS_API_KEY=your-api-key

# Groww Trading API (Indian stocks - NSE, BSE)
GROWW_API_KEY=your-groww-api-key
GROWW_API_SECRET=your-groww-api-secret
# Enable/disable Groww provider (default: true)
ENABLE_GROWW=true

# Zerodha Kite Connect (Indian stocks - NSE, BSE)
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_API_SECRET=your-zerodha-api-secret
ZERODHA_ACCESS_TOKEN=your-access-token
# Enable/disable Zerodha provider (default: true)
ENABLE_ZERODHA=true

# Yahoo Finance (Global stocks - no key required)
# Enable/disable Yahoo provider (default: true)
ENABLE_YAHOO=true

# Provider Routing Configuration
# ENABLE_PROVIDER_ROUTING=true
# DEFAULT_PROVIDER_INDIAN=groww
# DEFAULT_PROVIDER_US=yahoo

# =============================================
# Web Search API Keys (Fallback)
# =============================================
# Exa → Tavily ( Perplexity →in priority order)
EXASEARCH_API_KEY=your-api-key
PERPLEXITY_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# =============================================
# LangSmith (Observability)
# =============================================
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=true
