# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# J-Quants API (日本株データ) — https://jpx-jquants.com/
# メール/パスワードを設定すれば自動でトークン取得・更新します（推奨）
JQUANTS_MAIL=your-email@example.com
JQUANTS_PASSWORD=your-password
JQUANTS_REFRESH_TOKEN=  # 省略可: 有効なリフレッシュトークンがある場合のみ

# データプロバイダー切替え
STOCK_PROVIDER=auto       # auto | jquants | stooq
FINANCE_PROVIDER=auto     # auto | jquants | yahoo

# EDINET API (有価証券報告書) — https://api.edinet-fsa.go.jp/
EDINET_API_KEY=your-edinet-api-key

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key

# X/Twitter API (enables x_search tool for public sentiment research)
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith 
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=kabuto
LANGSMITH_TRACING=false
