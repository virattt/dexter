# LLM API Keys
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
XAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-api-key
MOONSHOT_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# Stock Market API Key
FINANCIAL_DATASETS_API_KEY=your-api-key

# Finnhub (optional fallback for prices/news when FD is down or rate-limited; 60 calls/min free tier)
# FINNHUB_API_KEY=your-api-key

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-api-key
PERPLEXITY_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# X/Twitter API (enables x_search tool for public sentiment research)
X_BEARER_TOKEN=your-bearer-token

# tastytrade (broker integration: positions, balances, options, theta scan/preview, dry-run; optional live order flow)
# See docs/PRD-TASTYTRADE-INTEGRATION.md. Operator states: not_connected -> read_only (accounts, positions, theta_scan, strategy_preview, order_dry_run) -> trading_enabled. Run /tastytrade-status in CLI.
TASTYTRADE_CLIENT_ID=your-oauth-client-id
TASTYTRADE_CLIENT_SECRET=your-oauth-client-secret
TASTYTRADE_SANDBOX=true
# Set to true to enable live order tools (live_orders, submit_order, cancel_order). Dry-run and preview are available in read-only without this.
# TASTYTRADE_ORDER_ENABLED=false
# When true, heartbeat compares live tastytrade positions to SOUL/PORTFOLIO target and flags drift: >5% above target (overweight) or >3% below for Core Compounders (underweight). See docs/TASTYTRADE.md.
# TASTYTRADE_HEARTBEAT_ENABLED=false
# Phase 5 theta workflows read ~/.dexter/THETA-POLICY.md for allowed underlyings, no-call list, delta/DTE defaults, and sizing caps.

# Hyperliquid (optional; defaults to https://api.hyperliquid.xyz)
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# Phase 9: live position sync. Set to your wallet address (42-char hex) to enable hyperliquid_positions and hyperliquid_sync_portfolio.
# HYPERLIQUID_ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000
# Phase 10: live order execution. Set to true AND set HYPERLIQUID_PRIVATE_KEY to enable hyperliquid_submit_order, hyperliquid_live_orders, hyperliquid_cancel_order. Preview-only tools (hyperliquid_order_preview) do not require this.
# HYPERLIQUID_ORDER_ENABLED=false
# HYPERLIQUID_PRIVATE_KEY=  # Ethereum private key (hex, 0x-prefixed or raw 64-char) for signing HL orders. Keep secret.

# AI Hedge Fund (double-check validation: 18 analyst agents as second opinion on portfolio)
# Requires AIHF backend running (https://github.com/eliza420ai-beep/ai-hedge-fund)
# AIHF_API_URL=http://localhost:8000
# AIHF_REQUEST_TIMEOUT_MS=180000

# LangSmith (set key + LANGSMITH_TRACING=true to trace tool calls and debug failures)
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=true
