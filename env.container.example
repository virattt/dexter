# Copy to env.container and add only the keys you need inside the container.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=

FINANCIAL_DATASETS_API_KEY=
EXASEARCH_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
X_BEARER_TOKEN=

LANGSMITH_TRACING=false

# Hardened defaults. Set to "true" only when you explicitly need the feature.
DEXTER_ALLOW_PRIVATE_NETWORK=false
DEXTER_ALLOW_OPEN_WHATSAPP=false
DEXTER_ENABLE_AUTOMATION=false
DEXTER_ENABLE_BROWSER=false
DEXTER_ENABLE_MEMORY=false
